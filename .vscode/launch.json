{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug OpenFang Daemon",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/target/debug/openfang.exe",
      "args": ["start"],
      "cwd": "${workspaceFolder}",
      "env": {
        "RUST_BACKTRACE": "1",
        "RUST_LOG": "info",
        "_NO_DEBUG_HEAP": "1"
      },
      "sourceLanguages": ["rust"],
      "terminal": "integrated",
      "stopOnEntry": false
    },
    {
      "name": "Debug OpenFang Desktop (GUI)",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/target/debug/openfang-desktop.exe",
      "args": [],
      "cwd": "${workspaceFolder}",
      "env": {
        "RUST_BACKTRACE": "1",
        "RUST_LOG": "info",
        "_NO_DEBUG_HEAP": "1"
      },
      "sourceLanguages": ["rust"],
      "stopOnEntry": false
    }
  ]
}